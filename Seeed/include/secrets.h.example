// Copy to secrets.h (gitignored) and fill in.
#pragma once

// WiFi and hub fields below are only a fallback, used if this board has
// never been adopted over BLE (see include/ble_provision.h). Once adopted —
// via the hub's "scan for IJ_ frames" / "adopt" flow, same as a real InkJoy
// frame — those values are saved to NVS and take priority over these
// compile-time ones. Leave the placeholders as-is if you plan to always
// adopt over BLE instead.
#define WIFI_SSID     "your-wifi-ssid"
#define WIFI_PASSWORD "your-wifi-password"

// joyous-hub host — local MQTT broker (listen_mqtt, default :11883) and HTTP
// image server (listen_http, default :18080) both live on this host.
#define HUB_HOST      "hubhost.local"
#define HUB_MQTT_PORT 11883

// NTP / local time — needed for msgid timestamps and wifi_sleep window checks.
// POSIX TZ string, e.g. "PST8PDT,M3.2.0,M11.1.0" for US Pacific.
#define NTP_TZ_INFO   "UTC0"
