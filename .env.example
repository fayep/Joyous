# Copy to .env and fill in locally. Never commit .env.
#
# For the Joyous hub, prefer config.yaml instead:
#   macOS:  ~/Library/Application Support/Joyous/config.yaml
#   Linux:  ~/.config/Joyous/config.yaml
# See joyous-hub/config.yaml.example
INKJOY_MQTT_USER=
INKJOY_MQTT_PASSWORD=
# Optional dev override for link-time metadata; release builds use JOYOUS_SEAL at build time.
JOYOUS_SEAL=
INKJOY_SIGN_KEY=
INKJOY_EMAIL=
INKJOY_CLIENT_ID=AABBCCDDEEFF
INKJOY_DEVICE_ID=
